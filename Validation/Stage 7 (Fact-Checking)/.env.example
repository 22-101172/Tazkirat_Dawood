# Copy this file to `.env` (which is gitignored) and fill in your own values.
# The scripts read these via os.environ.

# Your Google Cloud / Vertex AI project ID (required to run the pipeline)
VERTEX_PROJECT_ID=your-gcp-project-id

# Contact email for the OpenAlex / Europe PMC "polite pool" (recommended)
CONTACT_EMAIL=your-email@example.com
